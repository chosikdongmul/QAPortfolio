---
import BaseLayout from "../layouts/BaseLayout.astro";
import PhotoGrid from "../components/PhotoGrid.astro";
import OtakuGauge from "../components/OtakuGauge.astro";
import { q1, q2 } from "../content/qna";
import { personal } from "../content/site";
import { linkifyHtml } from "../lib/linkify";
---

<BaseLayout title={`Q&A · ${personal.nameKr}`}>
  <section class="reveal py-8">
    <p class="text-xs font-semibold uppercase tracking-widest text-accent-400">에피드게임즈 지원서 특별 질문</p>
    <h1 class="mt-2 text-3xl font-extrabold text-offwhite sm:text-4xl">Q&amp;A</h1>
    <p class="mt-3 text-offwhite/70">
      거짓 없이, 편안한 마음으로 솔직하게 — 지원서가 원한 대로 이 탭은 조금 힘 빼고 사진으로 대신합니다.
    </p>
  </section>

  <section class="reveal rounded-2xl border border-white/10 bg-base-800 p-6 sm:p-8">
    <h2 class="text-lg font-bold text-offwhite">Q1. {q1.question}</h2>
    <p class="mt-3 text-xl font-medium text-accent-400">"{q1.headCopy}"</p>
    <p class="mt-2 text-sm text-offwhite/70">{q1.summary}</p>

    <div class="mt-5 flex flex-wrap gap-2">
      {q1.events.map((e) => (
        <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-offwhite/80">{e}</span>
      ))}
    </div>

    <div class="mt-6">
      <PhotoGrid photos={q1.photos} emptyHint="행사 사진 업로드 예정 (본인 촬영 사진)" placeholderCount={8} />
    </div>
  </section>

  <section class="reveal mt-10 rounded-2xl border border-white/10 bg-base-800 p-6 sm:p-8">
    <h2 class="text-lg font-bold text-offwhite">Q2. {q2.question}</h2>

    <div class="mt-6 flex flex-col items-center gap-6 sm:flex-row sm:items-start sm:gap-10">
      <OtakuGauge level={q2.level} maxLevel={q2.maxLevel} />
      <ul class="space-y-3 text-sm leading-relaxed text-offwhite/80">
        {q2.reasons.map((reason) => (
          <li class="flex gap-2">
            <span class="text-accent-500">·</span>
            <span set:html={linkifyHtml(reason)} />
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-8">
      <PhotoGrid photos={q2.photos} emptyHint="재현샷·코스프레 사진 업로드 예정" placeholderCount={4} />
    </div>
  </section>
</BaseLayout>
