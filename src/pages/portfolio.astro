---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import {
  skillDeepDives,
  featuredProjects,
  testCaseDoc,
  skills,
  achievements,
  externalAdvisory,
} from "../content/portfolio";
import { personal } from "../content/site";
import { withBase } from "../lib/url";
---

<BaseLayout title={`Portfolio · ${personal.nameKr}`}>
  <section class="reveal py-8">
    <h1 class="text-3xl font-extrabold text-offwhite sm:text-4xl">Portfolio</h1>
    <p class="mt-2 text-offwhite/70">핵심 스킬, 대표 프로젝트, 대외활동, 역량 및 자격</p>
  </section>

  <section class="reveal">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-offwhite/50">핵심 스킬 딥다이브</h2>
    <div class="mt-4 space-y-6">
      {skillDeepDives.map((skill) => (
        <div class="reveal rounded-2xl border border-white/10 bg-base-800 p-6">
          <h3 class="text-lg font-bold text-offwhite">{skill.name}</h3>
          <p class="mt-2 text-base font-medium leading-relaxed text-accent-400">"{skill.quote}"</p>
          <ul class="mt-4 space-y-2">
            {skill.points.map((point) => (
              <li class="flex gap-2 text-sm leading-relaxed text-offwhite/80">
                <span class="text-accent-400">·</span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
          {skill.photos.length > 0 && (
            <div class="mt-5 space-y-3">
              {skill.photos.map((photo) => (
                <figure class="reveal overflow-hidden rounded-xl border border-white/10 bg-base-900">
                  <img src={withBase(photo.src)} alt={photo.caption} loading="lazy" class="w-full object-cover" />
                  <figcaption class="p-2 text-xs text-offwhite/70">{photo.caption}</figcaption>
                </figure>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <section class="reveal mt-12">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-offwhite/50">Featured Project</h2>
    <div class="mt-4 grid gap-4">
      {featuredProjects.map((p) => <ProjectCard {...p} />)}
    </div>
  </section>

  <section class="reveal mt-12">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-offwhite/50">대외활동 — {externalAdvisory.role}</h2>
    <div class="mt-4 rounded-2xl border border-white/10 bg-base-800 p-6">
      <ul class="space-y-2">
        {externalAdvisory.points.map((point) => (
          <li class="flex gap-2 text-sm leading-relaxed text-offwhite/80">
            <span class="text-accent-400">·</span>
            <span>{point}</span>
          </li>
        ))}
      </ul>
      <dl class="mt-5 space-y-3 border-t border-white/10 pt-4 text-sm">
        <div>
          <dt class="text-offwhite/50">사업명</dt>
          <dd class="mt-1 text-offwhite">{externalAdvisory.projectName}</dd>
        </div>
        <div>
          <dt class="text-offwhite/50">연구개발과제명</dt>
          <dd class="mt-1 text-offwhite">{externalAdvisory.taskName}</dd>
        </div>
        <div>
          <dt class="text-offwhite/50">자문 내용</dt>
          <dd class="mt-1 text-offwhite">{externalAdvisory.advisoryDetail}</dd>
        </div>
      </dl>
      {externalAdvisory.photo && (
        <figure class="reveal mt-5 overflow-hidden rounded-xl border border-white/10 bg-base-900">
          <img src={withBase(externalAdvisory.photo.src)} alt={externalAdvisory.photo.caption} loading="lazy" class="w-full object-cover" />
          <figcaption class="p-2 text-xs text-offwhite/70">{externalAdvisory.photo.caption}</figcaption>
        </figure>
      )}
    </div>
  </section>

  <section class="reveal mt-12">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-offwhite/50">테스트 케이스 문서</h2>
    <div class="mt-4 rounded-2xl border border-white/10 bg-base-800 p-6">
      <h3 class="text-lg font-bold text-offwhite">{testCaseDoc.title}</h3>
      <p class="mt-2 text-sm leading-relaxed text-offwhite/70">{testCaseDoc.description}</p>

      {testCaseDoc.ready ? (
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            href={withBase(testCaseDoc.fileUrl)}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full bg-accent-500 px-5 py-2 text-sm font-semibold text-base-900"
          >
            문서 보기
          </a>
          <a
            href={withBase(testCaseDoc.fileUrl)}
            download
            class="rounded-full border border-white/20 px-5 py-2 text-sm font-semibold text-offwhite"
          >
            다운로드
          </a>
        </div>
      ) : (
        <p class="mt-4 inline-block rounded-full border border-dashed border-white/20 px-4 py-2 text-xs text-offwhite/50">
          준비 중 — 문서가 확정되면 이 자리에 "문서 보기 / 다운로드" 버튼이 표시됩니다
        </p>
      )}
    </div>
  </section>

  <section class="reveal mt-12">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-offwhite/50">Skills &amp; Tools</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      {skills.map((group) => (
        <div class="rounded-2xl border border-white/10 bg-base-800 p-5">
          <p class="font-bold text-accent-400">{group.category}</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-offwhite/80">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="reveal mt-12 mb-4">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-offwhite/50">Achievements</h2>
    <ul class="mt-4 space-y-3">
      {achievements.map((a) => (
        <li class="flex flex-col justify-between gap-1 rounded-xl border border-white/10 bg-base-800 p-4 sm:flex-row sm:items-center">
          <span class="text-offwhite">{a.name}</span>
          <span class="text-sm text-offwhite/50">{a.date}</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
