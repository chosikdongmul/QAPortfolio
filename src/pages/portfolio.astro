---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { featuredProjects, testCaseDoc, skills, achievements } from "../content/portfolio";
import { personal } from "../content/site";
import { withBase } from "../lib/url";
---

<BaseLayout title={`Portfolio · ${personal.nameKr}`}>
  <section class="reveal py-8">
    <h1 class="text-3xl font-extrabold text-offwhite sm:text-4xl">Portfolio</h1>
    <p class="mt-2 text-offwhite/70">프로젝트, 테스트 케이스 문서, 역량 및 자격</p>
  </section>

  <section class="reveal">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-offwhite/50">Featured Projects</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {featuredProjects.map((p) => <ProjectCard {...p} />)}
    </div>
  </section>

  <section class="reveal mt-12">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-offwhite/50">테스트 케이스 문서</h2>
    <div class="mt-4 rounded-2xl border border-white/10 bg-base-800 p-6">
      <h3 class="text-lg font-bold text-offwhite">{testCaseDoc.title}</h3>
      <p class="mt-2 text-sm leading-relaxed text-offwhite/70">{testCaseDoc.description}</p>

      {testCaseDoc.ready ? (
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            href={withBase(testCaseDoc.fileUrl)}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full bg-accent-500 px-5 py-2 text-sm font-semibold text-base-900"
          >
            문서 보기
          </a>
          <a
            href={withBase(testCaseDoc.fileUrl)}
            download
            class="rounded-full border border-white/20 px-5 py-2 text-sm font-semibold text-offwhite"
          >
            다운로드
          </a>
        </div>
      ) : (
        <p class="mt-4 inline-block rounded-full border border-dashed border-white/20 px-4 py-2 text-xs text-offwhite/50">
          준비 중 — 문서가 확정되면 이 자리에 "문서 보기 / 다운로드" 버튼이 표시됩니다
        </p>
      )}
    </div>
  </section>

  <section class="reveal mt-12">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-offwhite/50">Skills &amp; Tools</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      {skills.map((group) => (
        <div class="rounded-2xl border border-white/10 bg-base-800 p-5">
          <p class="font-bold text-accent-400">{group.category}</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-offwhite/80">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="reveal mt-12 mb-4">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-offwhite/50">Achievements</h2>
    <ul class="mt-4 space-y-3">
      {achievements.map((a) => (
        <li class="flex flex-col justify-between gap-1 rounded-xl border border-white/10 bg-base-800 p-4 sm:flex-row sm:items-center">
          <span class="text-offwhite">{a.name}</span>
          <span class="text-sm text-offwhite/50">{a.date}</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
