---
import { nav, personal } from "../content/site";
import { withBase } from "../lib/url";

const currentPath = Astro.url.pathname.replace(import.meta.env.BASE_URL.replace(/\/$/, ""), "") || "/";
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-base-900/90 backdrop-blur">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-5 py-3">
    <a href={withBase("/")} class="font-extrabold tracking-tight text-offwhite">
      {personal.nameKr} <span class="text-accent-400">·</span> {personal.nameEn}
    </a>

    <nav class="hidden gap-1 md:flex" aria-label="주요 탭">
      {nav.map((item) => {
        const active = currentPath === item.href;
        return (
          <a
            href={withBase(item.href)}
            class:list={[
              "rounded-full px-4 py-2 text-sm font-medium transition-colors",
              active ? "bg-accent-500 text-base-900" : "text-offwhite/80 hover:text-accent-400",
            ]}
            aria-current={active ? "page" : undefined}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <button
      id="nav-toggle"
      class="flex flex-col gap-1.5 p-2 md:hidden"
      aria-label="메뉴 열기"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span class="h-0.5 w-6 bg-offwhite"></span>
      <span class="h-0.5 w-6 bg-offwhite"></span>
      <span class="h-0.5 w-6 bg-offwhite"></span>
    </button>
  </div>

  <nav id="mobile-nav" class="hidden flex-col gap-1 border-t border-white/10 px-5 py-3 md:hidden" aria-label="모바일 탭">
    {nav.map((item) => {
      const active = currentPath === item.href;
      return (
        <a
          href={withBase(item.href)}
          class:list={[
            "rounded-lg px-3 py-2 text-sm font-medium",
            active ? "bg-accent-500 text-base-900" : "text-offwhite/80",
          ]}
          aria-current={active ? "page" : undefined}
        >
          {item.label}
        </a>
      );
    })}
  </nav>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-nav");
  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("flex");
    menu?.classList.toggle("hidden", !isOpen);
    toggle.setAttribute("aria-expanded", String(!!isOpen));
  });
</script>
