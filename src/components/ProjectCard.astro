---
interface Props {
  title: string;
  period: string;
  role: string;
  highlight: string;
}
const { title, period, role, highlight } = Astro.props;
---

<article class="reveal rounded-2xl border border-white/10 bg-base-800 p-6 transition-colors hover:border-accent-500/50">
  <h3 class="text-lg font-bold text-offwhite">{title}</h3>
  <p class="mt-1 text-sm text-accent-400">{role} · {period}</p>
  <p class="mt-3 text-sm leading-relaxed text-offwhite/80">{highlight}</p>
</article>
